{
  "name": "viz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w @viz/protocol && npm run build -w @viz/host",
    "dev": "npm run build:packages && vite",
    "build": "npm run build:packages && tsc -b && vite build",
    "lint": "oxlint packages apps",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
